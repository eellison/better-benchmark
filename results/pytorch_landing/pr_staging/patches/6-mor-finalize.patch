From 8d664ddc25ec05910658273a59c101962e12b6ab Mon Sep 17 00:00:00 2001
From: Elias Ellison <elias.ellison@gmail.com>
Date: Wed, 15 Jul 2026 23:35:27 +0000
Subject: [PATCH 2/2] [inductor] Add config.triton_finalize_sum kill switch for
 the MOR Triton finalize-sum codegen

NOT part of the original feature (which was unconditional): adds
config.triton_finalize_sum (TORCHINDUCTOR_TRITON_FINALIZE_SUM, default on)
gating the triton_mor_finalize_sum codegen, so reviewers/users can restore
the ATen .sum(dim=0) finalize fallback without a source change.

written with claude code
---
 torch/_inductor/codegen/simd.py | 3 ++-
 torch/_inductor/config.py       | 6 ++++++
 2 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/torch/_inductor/codegen/simd.py b/torch/_inductor/codegen/simd.py
index cf7bdff0504..a1b5ac34653 100644
--- a/torch/_inductor/codegen/simd.py
+++ b/torch/_inductor/codegen/simd.py
@@ -2468,7 +2468,8 @@ class SIMDScheduling(BaseScheduling):
             # Use a generated Triton finalize kernel for sum reduction
             # to get coalesced memory access instead of ATen's generic reduce.
             use_triton_finalize = (
-                partial_accum.reduction_type == "sum"
+                config.triton_finalize_sum
+                and partial_accum.reduction_type == "sum"
                 and not V.graph.cpp_wrapper
                 and V.graph.device_type == "cuda"
             )
diff --git a/torch/_inductor/config.py b/torch/_inductor/config.py
index 0af0521eac3..307b124f9c6 100644
--- a/torch/_inductor/config.py
+++ b/torch/_inductor/config.py
@@ -1005,6 +1005,12 @@ conv_1x1_as_mm = False
 # enabling both of these will implicitly disable split_reductions
 split_reductions = os.getenv("TORCHINDUCTOR_SPLIT_REDUCTIONS", "1") == "1"
 
+# Finalize multi-output split-reduction sums with a generated 2D Triton kernel
+# (coalesced loads + atomic_add) instead of ATen's generic .sum(dim=0) over the
+# partial-sum workspace. CUDA python-wrapper only; kill switch for the
+# triton_mor_finalize_sum codegen.
+triton_finalize_sum = os.getenv("TORCHINDUCTOR_TRITON_FINALIZE_SUM", "1") == "1"
+
 # A deterministic mode that skips any on device benchmarking in Inductor
 # if we know they affect numerics.  WARNING: Expect perf hit in this mode.
 deterministic = os.getenv("TORCHINDUCTOR_DETERMINISTIC") == "1"
