From a73d1583b348acfadfb2089e87e9c94572120910 Mon Sep 17 00:00:00 2001
From: Elias Ellison <elias.ellison@gmail.com>
Date: Fri, 5 Jun 2026 15:40:38 +0000
Subject: [PATCH] [inductor] Canonicalize reciprocal(sqrt(x)) to rsqrt(x)
 (mean_7639, 1.41x->1.09x)

Gate: always-on (universally correct algebraic identity: 1/sqrt(x) == rsqrt(x))
Adds post_grad pattern to fuse reciprocal+sqrt into single rsqrt op, saving one instruction per element.

Also handles div(1, sqrt(x)) -> rsqrt(x) variant.

written with claude code
---
 torch/_inductor/fx_passes/post_grad.py | 45 ++++++++++++++++++++++++++
 1 file changed, 45 insertions(+)

diff --git a/torch/_inductor/fx_passes/post_grad.py b/torch/_inductor/fx_passes/post_grad.py
index 93195fa3075..c818d572bf8 100644
--- a/torch/_inductor/fx_passes/post_grad.py
+++ b/torch/_inductor/fx_passes/post_grad.py
@@ -2085,6 +2085,51 @@ def cat_splitwithsizes_replace(match, input_):
     return input_
 
 
+################################################################################
+# Algebraic simplification: reciprocal(sqrt(x)) -> rsqrt(x)
+# This is a universally correct identity: 1/sqrt(x) == rsqrt(x)
+# Saves one op in the generated kernel.
+################################################################################
+
+
+@register_graph_pattern(
+    CallFunction(
+        aten.reciprocal.default,
+        CallFunction(aten.sqrt.default, KeywordArg("x")),
+    ),
+    # pyrefly: ignore [bad-argument-type]
+    pass_dict=pass_patterns[1],
+)
+def reciprocal_sqrt_to_rsqrt(match: Match, x):
+    """reciprocal(sqrt(x)) -> rsqrt(x)"""
+
+    def repl(x):
+        return aten.rsqrt(x)
+
+    match.replace_by_example(repl, [x])
+
+
+@register_graph_pattern(
+    CallFunction(
+        aten.div.Tensor,
+        KeywordArg("one"),
+        CallFunction(aten.sqrt.default, KeywordArg("x")),
+    ),
+    # pyrefly: ignore [bad-argument-type]
+    pass_dict=pass_patterns[1],
+)
+def div_one_sqrt_to_rsqrt(match: Match, one, x):
+    """div(1, sqrt(x)) -> rsqrt(x) when the numerator is 1"""
+    # Only match when the numerator is the scalar 1 (int or float)
+    if not isinstance(one, (int, float)) or one != 1:
+        return
+
+    def repl(x):
+        return aten.rsqrt(x)
+
+    match.replace_by_example(repl, [x])
+
+
 def view_to_reshape(gm):
     """
     Replace view ops in the GraphModule to reshape ops.
-- 
