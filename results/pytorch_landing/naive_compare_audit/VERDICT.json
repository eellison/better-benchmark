    "order30_c465f1751c6 (scheduler mutation recursion fix)": "GPTNeo+89%/DistilBert+78%/DebertaV2/densenet/TrOCR +28-89%",
    "order40_44802547aa9 (_get_nd_reduction_numels crash fix)": "pytorch_unet(=R1) +293% + deit_tiny +29%",
